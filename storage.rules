rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    function uidPrefixed(fileName) {
      return fileName.matches('^' + request.auth.uid + '(_.*)?(\\..+)?$');
    }

    // Chat images (current app path: chat_images/{uid}/{fileName})
    match /chat_images/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() 
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Legacy chat-images path (kept for backward compatibility)
    match /chat-images/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Voice messages
    match /voice_messages/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isAudio()
                   && request.resource.size < 15 * 1024 * 1024; // Max 15MB
    }

    // Generic chat file uploads
    match /chat_files/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024; // Max 20MB
    }
    
    // User avatars (flat naming pattern: avatars/{uid}_{timestamp}.jpg)
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // User avatars (folder naming pattern: avatars/{uid}/{fileName})
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Covers (flat naming pattern: covers/{uid}_{timestamp}.jpg)
    match /covers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Covers (folder naming pattern: covers/{uid}/cover.jpg)
    match /covers/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Business/partner logos (logos/{userId}/logo.jpg)
    match /logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 2 * 1024 * 1024; // Max 2MB
    }

    // Partner gallery
    match /gallery/{partnerId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == partnerId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Partner menu images
    match /menus/{partnerId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == partnerId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // User stories
    match /stories/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Premium offers media (flat naming: premium_offers/{uid}_{timestamp})
    match /premium_offers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && (isImage() || isVideo())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Offer media (flat naming: offers/{uid}_{timestamp})
    match /offers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && (isImage() || isVideo())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Invitation media — uid subfolder enforces upload ownership.
    // Modern apps upload to: invitations/{userId}/{fileName}
    // Legacy app uploads to: invitations/{invitationId}/{userId}/{fileName}
    
    // 1. Modern upload path pattern
    match /invitations/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 50 * 1024 * 1024; // Max 50MB
    }

    // 2. Legacy subfolder path pattern
    match /invitations/{invitationId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // AI invitation card images (written only by Cloud Functions Admin SDK)
    match /invitation_cards/{userId}/{draftGroupId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy flat path (read-only for backwards compatibility with existing URLs)
    // Example: invitations/{invitationId}/{fileName} (where fileName is not a UID folder)

    // User place images
    match /users/{userId}/places/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Featured posts (Elite animated posts – background images)
    match /featured_posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (request.resource.contentType == null || request.resource.contentType.matches('image/.*'))
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Community posts media (images/videos for feed posts)
    match /community-posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Featured posts background images (Business Pro feature)
    match /featured_posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Business feedback/complaint proof media
    match /feedback_media/{businessId}/{fileName} {
      allow read: if true;
      allow write: if (isImage() || isVideo() || isAudio())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Google Business source photos (synced during registration)
    match /business_photos/{userId}/{fileName} {
      allow read: if true;
      // Some clients send blobs with missing/wrong contentType even when metadata is set — allow common image extensions.
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                     isImage() ||
                     request.resource.contentType == null ||
                     fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$')
                   );
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
