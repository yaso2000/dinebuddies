rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    function uidPrefixed(fileName) {
      return fileName.matches('^' + request.auth.uid + '(_.*)?(\\..+)?$');
    }

    function isAdminOrPanelStaff() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.uid == 'xTgHC1v00LZIZ6ESA9YGjGU5zW33' ||
        (request.auth.token.email != null &&
          request.auth.token.email.matches('(?i)^(admin@dinebuddies\\.com|yaser@dinebuddies\\.com|info@dinebuddies\\.com\\.au|y\\.abohamed@gmail\\.com)$')) ||
        (
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'moderator', 'support', 'staff']
        )
      );
    }

    // Host of a hosted invitation (social + personal — Firestore social_invitations, legacy private_invitations).
    function isPrivateInvitationHost(invitationId) {
      let socialDoc = firestore.get(/databases/(default)/documents/social_invitations/$(invitationId));
      let legacyDoc = firestore.get(/databases/(default)/documents/private_invitations/$(invitationId));
      return (socialDoc != null && (
               socialDoc.data.authorId == request.auth.uid ||
               (socialDoc.data.author is map && socialDoc.data.author.get('id', '') == request.auth.uid)
             )) ||
             (legacyDoc != null && (
               legacyDoc.data.authorId == request.auth.uid ||
               (legacyDoc.data.author is map && legacyDoc.data.author.get('id', '') == request.auth.uid)
             ));
    }

    // Quarantine: user uploads here; Cloud Function moves to public path after Vision scan
    match /quarantine/{userId}/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 15 * 1024 * 1024;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Chat images (current app path: chat_images/{uid}/{fileName})
    match /chat_images/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() 
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Legacy chat-images path (kept for backward compatibility)
    match /chat-images/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Voice messages
    match /voice_messages/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isAudio()
                   && request.resource.size < 15 * 1024 * 1024; // Max 15MB
    }

    // Generic chat file uploads
    match /chat_files/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024; // Max 20MB
    }
    
    // User avatars (flat naming pattern: avatars/{uid}_{timestamp}.jpg)
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // User avatars (folder naming pattern: avatars/{uid}/{fileName})
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Covers (flat naming pattern: covers/{uid}_{timestamp}.jpg)
    match /covers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Covers (folder naming pattern: covers/{uid}/cover.jpg)
    match /covers/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Business/partner logos (logos/{userId}/logo.jpg)
    match /logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 2 * 1024 * 1024; // Max 2MB
    }

    // Partner gallery
    match /gallery/{partnerId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == partnerId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Partner menu images
    match /menus/{partnerId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == partnerId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // User stories
    match /stories/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Premium offers media (flat naming: premium_offers/{uid}_{timestamp})
    match /premium_offers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && (isImage() || isVideo())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Offer media (flat naming: offers/{uid}_{timestamp})
    match /offers/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && uidPrefixed(fileName)
                   && (isImage() || isVideo())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Invitation media — uid subfolder enforces upload ownership.
    // Modern apps upload to: invitations/{userId}/{fileName}
    // Legacy app uploads to: invitations/{invitationId}/{userId}/{fileName}
    
    // 1. Modern upload path pattern
    match /invitations/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 50 * 1024 * 1024; // Max 50MB
    }

    // 2. Legacy subfolder path pattern
    match /invitations/{invitationId}/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // AI invitation card images (written only by Cloud Functions Admin SDK)
    match /invitation_cards/{userId}/{draftGroupId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy flat path (read-only for backwards compatibility with existing URLs)
    // Example: invitations/{invitationId}/{fileName} (where fileName is not a UID folder)

    // User place images
    match /users/{userId}/places/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Featured posts (Elite animated posts – background images)
    match /featured_posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (request.resource.contentType == null || request.resource.contentType.matches('image/.*'))
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Community posts media (images/videos for feed posts)
    match /community-posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && (isImage() || isVideo())
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Standalone AI Design Studio generated images
    match /ai-design-studio/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Business motion / Smart Post Studio cover images
    match /business-motion/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Legacy AI image path (server-side uploads before folder fix — read-only for existing URLs)
    match /users/{userId}/invitations/ai/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Featured posts background images (Business Pro feature)
    match /featured_posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }

    // Business feedback/complaint proof media
    match /feedback_media/{businessId}/{fileName} {
      allow read: if true;
      allow write: if (isImage() || isVideo() || isAudio())
                   && request.resource.size < 30 * 1024 * 1024;
    }

    // Business-imported restaurant cover images (server upload on publish)
    match /restaurants/covers/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Private invitation share card JPEG (9:16) — public read for WhatsApp/Facebook OG crawlers
    match /private-invitations/{invitationId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && fileName == 'share-og.jpg'
                   && isImage()
                   && request.resource.size < 5 * 1024 * 1024
                   && isPrivateInvitationHost(invitationId);
    }

    // Google Business source photos (synced during registration)
    match /business_photos/{userId}/{fileName} {
      allow read: if true;
      // Some clients send blobs with missing/wrong contentType even when metadata is set — allow common image extensions.
      allow write: if isSignedIn()
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && (
                     isImage() ||
                     request.resource.contentType == null ||
                     fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$')
                   );
    }

    // Admin demo user profile uploads (manual seeding from admin panel)
    match /demo-users/uploads/{adminUid}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn()
                   && request.auth.uid == adminUid
                   && isAdminOrPanelStaff()
                   && isImage()
                   && request.resource.size < 8 * 1024 * 1024;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
