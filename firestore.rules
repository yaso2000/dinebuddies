rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.admin == true || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Business accounts (role 'business'); legacy 'partner' kept for backward compatibility
    function isPartner() {
      return isSignedIn() && 
             (request.auth.token.partner == true || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'business' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner');
    }

    function isCommunityMember(partnerId) {
      let me = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let partner = get(/databases/$(database)/documents/users/$(partnerId)).data;
      let joined = me.get('joinedCommunities', []);
      let members = partner.get('communityMembers', []);
      return request.auth.uid == partnerId ||
             request.auth.uid in members ||
             partnerId in joined;
    }

    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return request.auth.uid in chat.participants;
    }
    
    // Invitation chat: only host or joined participants (public invitations)
    function isPublicInvitationChatParticipant(invitationId) {
      let inv = get(/databases/$(database)/documents/invitations/$(invitationId)).data;
      let isHost = inv.get(['author', 'id'], '') == request.auth.uid || inv.get('authorId', '') == request.auth.uid;
      let joined = inv.get('joined', []);
      let isJoined = request.auth.uid in joined;
      return isHost || isJoined;
    }
    
    // Invitation chat: only host or accepted invitees (private invitations).
    // LEGACY-DATA RISK: If rsvps is missing or a user has no rsvps entry, they will be denied;
    // ensure the app sets rsvps when users accept, and consider migrating old docs if needed.
    function isPrivateInvitationChatParticipant(invitationId) {
      let inv = get(/databases/$(database)/documents/private_invitations/$(invitationId)).data;
      let isHost = inv.get(['author', 'id'], '') == request.auth.uid || inv.get('authorId', '') == request.auth.uid;
      let invitedFriends = inv.get('invitedFriends', []);
      let rsvps = inv.get('rsvps', {});
      let invited = request.auth.uid in invitedFriends;
      let accepted = rsvps[request.auth.uid] == 'accepted';
      return isHost || (invited && accepted);
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      allow get: if true; // Keep temporarily until remaining cross-user reads are migrated
      allow list: if isAdmin() &&
                   request.query.limit != null &&
                   request.query.limit <= 200;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && 
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'accountType']);
      allow update: if isAdmin();
      // Allow any signed-in user to increment profile view counter only
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['businessInfo']) &&
                       request.resource.data.businessInfo.diff(resource.data.businessInfo).affectedKeys()
                         .hasOnly(['profileViews']);
      
      // SUPER OWNER PROTECTION:
      // 1. Only Super Owner can delete Admins.
      // 2. Admins cannot delete themselves.
      // 3. Admins can delete regular users.
      // 4. Regular users can delete themselves.
      
      allow delete: if 
        // Case 1: Super Owner can delete ANYONE (including other admins)
        (request.auth.token.email.matches('.*y.abohamed@gmail.com') || 
         request.auth.token.email == 'admin@dinebuddies.com' ||
         request.auth.uid == 'xTgHC1v00LZIZ6ESA9YGjGU5zW33') ||
         
        // Case 2: Admin deleting a non-admin user
        (isAdmin() && resource.data.role != 'admin') ||
        
        // Case 3: Regular user deleting themselves (if not admin)
        (isOwner(userId) && resource.data.role != 'admin');
      
      // USER REVIEWS SUBCOLLECTION
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;
        
        // Only signed-in users can create reviews
        allow create: if isSignedIn() && 
                         request.resource.data.fromUserId == request.auth.uid;
        
        // Only review author can update/delete their review
        allow update, delete: if isSignedIn() && 
                                 resource.data.fromUserId == request.auth.uid;
      }
      
      // USER PREFERENCES SUBCOLLECTION
      match /preferences/{docId} {
        // User can read their own preferences
        allow read: if isOwner(userId);
        
        // User can create/update their own preferences
        allow create, update: if isOwner(userId);
        
        // User can delete their own preferences
        allow delete: if isOwner(userId);
      }
    }
    
    // ============================================
    // PUBLIC PROFILES (READ-ONLY PROJECTION)
    // ============================================

    match /public_profiles/{uid} {
      // Public-facing display/search projection
      allow get: if true;
      allow list: if request.query.limit != null && request.query.limit <= 20;

      // Backend-synced only (Cloud Functions trigger/callables)
      allow create, update, delete: if false;
    }

    // ============================================
    // INVITATIONS COLLECTION
    // ============================================
    
    match /invitations/{invitationId} {
      allow read: if true; // Allow public read
      
      allow create: if isSignedIn() && 
                       request.resource.data.author.id == request.auth.uid;
      
      // Host can update
      allow update: if isSignedIn() && 
                       resource.data.author.id == request.auth.uid;
      
      // Users can add themselves to requests (JOIN REQUEST)
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       request.resource.data.requests.hasAll(resource.data.requests) &&
                       request.resource.data.requests.hasOnly([request.auth.uid].concat(resource.data.requests));
      
      // Users can remove themselves from requests
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       resource.data.requests.hasAll(request.resource.data.requests);
      
      allow update: if isAdmin();
      
      allow delete: if isSignedIn() && 
                       (resource.data.author.id == request.auth.uid || isAdmin());
      
      // MESSAGES SUBCOLLECTION (Community Chat) — only host or joined participants
      match /messages/{messageId} {
        allow read: if isSignedIn() && isPublicInvitationChatParticipant(invitationId);
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         isPublicInvitationChatParticipant(invitationId);
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // PRIVATE INVITATIONS COLLECTION (separate from public)
    // ============================================

    match /private_invitations/{invitationId} {
      // Read/list only for host or invited users (server-enforced)
      allow get, list: if isSignedIn() &&
                         (
                           resource.data.authorId == request.auth.uid ||
                           (resource.data.author != null &&
                            resource.data.author.id == request.auth.uid) ||
                           request.auth.uid in resource.data.invitedFriends
                         );

      // Any signed-in user can create (author must be self)
      allow create: if isSignedIn() &&
                       (request.resource.data.authorId == request.auth.uid ||
                        request.resource.data.author.id == request.auth.uid);

      // Host can update freely; invited friends can update only their RSVP
      allow update: if isSignedIn() &&
                       (resource.data.authorId == request.auth.uid ||
                        (resource.data.author != null &&
                         resource.data.author.id == request.auth.uid) ||
                        (request.auth.uid in resource.data.invitedFriends &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvps', 'updatedAt']) &&
                         request.resource.data.rsvps.diff(resource.data.rsvps).affectedKeys().hasOnly([request.auth.uid])));

      // Only host or admin can delete
      allow delete: if isSignedIn() &&
                       (resource.data.authorId == request.auth.uid ||
                        (resource.data.author != null &&
                         resource.data.author.id == request.auth.uid) ||
                        isAdmin());

      // MESSAGES SUBCOLLECTION (Private Group Chat) — only host or accepted invitees
      match /messages/{messageId} {
        allow read: if isSignedIn() && isPrivateInvitationChatParticipant(invitationId);
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         isPrivateInvitationChatParticipant(invitationId);
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // CHATS COLLECTION (Group Chats)
    // ============================================

    
    match /chats/{chatId} {
      // Only chat participants or admins
      allow read: if isSignedIn() &&
                    (request.auth.uid in resource.data.participants || isAdmin());
      
      // Creator must be a participant
      allow create: if isSignedIn() &&
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants/admin can update
      allow update: if isSignedIn() &&
                      (request.auth.uid in resource.data.participants || isAdmin());
      
      // Only admin can delete
      allow delete: if isAdmin();
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Only chat participants/admin can read messages
        allow read: if isSignedIn() && (isChatParticipant(chatId) || isAdmin());
        
        // Sender must be a participant/admin
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid &&
                         (isChatParticipant(chatId) || isAdmin());
        
        // Sender can update their own message
        allow update: if isSignedIn() && 
                         isOwner(resource.data.senderId);
        
        // Sender or admin can delete message
        allow delete: if isSignedIn() && 
                         (isOwner(resource.data.senderId) || isAdmin());
      }
    }
    
    // ============================================
    // CONVERSATIONS COLLECTION (1-on-1 Chats)
    // ============================================
    
    match /conversations/{conversationId} {
      // Only participants can read the conversation document
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Security: enforce strict 1:1 participant shape to prevent forged conversation graphs
      allow create: if isSignedIn() &&
                      request.resource.data.participants is list &&
                      request.resource.data.participants.size() == 2 &&
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants can update (lastMessage, unreadBy, typing)
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Participants or Admin can delete
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // Security: constrain message create schema and sender ownership
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.keys().hasOnly(['senderId', 'text', 'type', 'createdAt', 'status', 'reactions', 'replyTo', 'audioUrl', 'imageUrl', 'fileUrl', 'duration']) &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if isSignedIn() && 
                         resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() && 
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // REVIEWS COLLECTION (Top-Level)
    // ============================================
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // REPORTS & SYSTEM MESSAGES
    // ============================================

    match /reports/{reportId} {
      allow read: if isAdmin();
      // Security: bind report ownership/status to authenticated reporter
      allow create: if isSignedIn() &&
                      request.resource.data.reporterId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /system_messages/{messageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /partner_notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
      // Client-side create is self-only; cross-user partner notifications must use trusted backend callable.
      allow create: if isSignedIn() &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.restaurantId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
    }
    
    // ============================================
    // POSTS & FEED
    // ============================================

    match /communityPosts/{postId} {
      // Anyone can read posts
      allow read: if true;
      // Any signed in user can create a post
      allow create: if isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.authorId == request.auth.uid ||
          request.resource.data.partnerId == request.auth.uid ||
          (request.resource.data.author != null &&
           request.resource.data.author.id == request.auth.uid)
        );
      // Only the author or an admin can update/delete their post
      allow update, delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
    }

    match /stories/{storyId} {
      // Anyone can read stories
      allow read: if true;
      // Security: enforce ownership on story creation (prevent impersonation)
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.authorId == request.auth.uid ||
        request.resource.data.partnerId == request.auth.uid ||
        (request.resource.data.author != null && request.resource.data.author.id == request.auth.uid)
      );
      // Only the author or an admin can fully update/delete their story
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.authorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
      // Any signed-in user can add their reaction / like / view (append-only fields)
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'likes', 'views']);
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Client-side create is limited to self-only notifications to block cross-user spoofing.
      // Cross-user/system notifications must be created via trusted backend callables.
      allow create: if isSignedIn() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // DYNAMIC PRICING (PUBLIC)
    // ============================================

    match /subscriptionPlans/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /creditPacks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // APP CONFIGURATION & SETTINGS
    // ============================================
    
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /global_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // PREMIUM OFFERS (PARTNERS ONLY)
    // ============================================
    
    match /offers/{offerId} {
      allow read: if true;
      
      // Create: Must be partner, and partnerId must match their UID
      allow create: if isPartner() && 
                       request.resource.data.partnerId == request.auth.uid;
      
      // Update: Must be partner, own the offer, and cannot modify protected fields
      allow update: if isPartner() && 
                       resource.data.partnerId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['platform_commission', 'global_status']);
      
      // Delete: Partners can delete their own offers, and admins can delete any offer
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /active_offers/{offerId} {
      allow read: if true;
      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /special_offers/{offerId} {
      allow read: if true;
      // Security: bind created special offer to authenticated partner owner
      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }
    
    // ============================================
    // COMMUNITIES COLLECTION (Community Chat)
    // ============================================

    match /communities/{partnerId} {
      // Only members, partner owner, or admins can read community info
      allow read: if isSignedIn() && (isCommunityMember(partnerId) || isAdmin());

      // Only the partner (owner) can create/update the community document
      allow create, update: if isOwner(partnerId) || isAdmin();
      allow delete: if isAdmin();

      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Only community members/owner/admin can read
        allow read: if isSignedIn() && (isCommunityMember(partnerId) || isAdmin());

        // Only community members/owner/admin can send
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         (isCommunityMember(partnerId) || isAdmin());

        // Sender can update their own message (edit text, etc.)
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;

        // Community members can update reactions only
        allow update: if isSignedIn() &&
                         (isCommunityMember(partnerId) || isAdmin()) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

        // Admin can update anything
        allow update: if isAdmin();

        // Sender or admin can delete
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // FINAL SECURITY: DENY ALL OTHER COLLECTIONS
    // ============================================
    
    match /{document=**} {
      allow read, write: if isAdmin(); // Only admins can access undefined collections
    }
  }
}
