rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.admin == true || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    function isPartner() {
      return isSignedIn() && 
             (request.auth.token.partner == true || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner');
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      allow get: if true; // Allow reading individual user documents (public profiles)
      allow list: if true; // Allow querying/listing users collection (for partner directory)
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && 
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'accountType']);
      allow update: if isAdmin();
      
      // SUPER OWNER PROTECTION:
      // 1. Only Super Owner can delete Admins.
      // 2. Admins cannot delete themselves.
      // 3. Admins can delete regular users.
      // 4. Regular users can delete themselves.
      
      allow delete: if 
        // Case 1: Super Owner can delete ANYONE (including other admins)
        (request.auth.token.email.matches('.*y.abohamed@gmail.com') || 
         request.auth.token.email == 'admin@dinebuddies.com' ||
         request.auth.uid == 'xTgHC1v00LZIZ6ESA9YGjGU5zW33') ||
         
        // Case 2: Admin deleting a non-admin user
        (isAdmin() && resource.data.role != 'admin' && resource.data.accountType != 'admin') ||
        
        // Case 3: Regular user deleting themselves (if not admin)
        (isOwner(userId) && resource.data.role != 'admin' && resource.data.accountType != 'admin');
      
      // USER REVIEWS SUBCOLLECTION
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;
        
        // Only signed-in users can create reviews
        allow create: if isSignedIn() && 
                         request.resource.data.fromUserId == request.auth.uid;
        
        // Only review author can update/delete their review
        allow update, delete: if isSignedIn() && 
                                 resource.data.fromUserId == request.auth.uid;
      }
      
      // USER PREFERENCES SUBCOLLECTION
      match /preferences/{docId} {
        // User can read their own preferences
        allow read: if isOwner(userId);
        
        // User can create/update their own preferences
        allow create, update: if isOwner(userId);
        
        // User can delete their own preferences
        allow delete: if isOwner(userId);
      }
    }
    
    // ============================================
    // INVITATIONS COLLECTION
    // ============================================
    
    match /invitations/{invitationId} {
      allow read: if true; // Allow public read
      
      allow create: if isSignedIn() && 
                       request.resource.data.author.id == request.auth.uid;
      
      // Host can update
      allow update: if isSignedIn() && 
                       resource.data.author.id == request.auth.uid;
      
      // Users can add themselves to requests (JOIN REQUEST)
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       request.resource.data.requests.hasAll(resource.data.requests) &&
                       request.resource.data.requests.hasOnly([request.auth.uid].concat(resource.data.requests));
      
      // Users can remove themselves from requests
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       resource.data.requests.hasAll(request.resource.data.requests);
      
      allow update: if isAdmin();
      
      allow delete: if isSignedIn() && 
                       (resource.data.author.id == request.auth.uid || isAdmin());
      
      // MESSAGES SUBCOLLECTION (Community Chat)
      match /messages/{messageId} {
        // Anyone signed in can read messages
        allow read: if isSignedIn();
        
        // Anyone signed in can create messages
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid;
        
        // Sender can update their own message
        allow update: if isSignedIn() && 
                         resource.data.senderId == request.auth.uid;
        
        // Sender or admin can delete message
        allow delete: if isSignedIn() && 
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }
    
    // ============================================
    // CHATS COLLECTION (Group Chats)
    // ============================================
    
    match /chats/{chatId} {
      // Anyone signed in can read (we'll filter in app)
      allow read: if isSignedIn();
      
      // Anyone can create chat
      allow create: if isSignedIn();
      
      // Anyone can update chat
      allow update: if isSignedIn();
      
      // Only admin can delete
      allow delete: if isAdmin();
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Anyone signed in can read messages
        allow read: if isSignedIn();
        
        // Anyone can create messages
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid;
        
        // Sender can update their own message
        allow update: if isSignedIn() && 
                         isOwner(resource.data.senderId);
        
        // Sender or admin can delete message
        allow delete: if isSignedIn() && 
                         (isOwner(resource.data.senderId) || isAdmin());
      }
    }
    
    // ============================================
    // CONVERSATIONS COLLECTION (1-on-1 Chats)
    // ============================================
    
    match /conversations/{conversationId} {
      // Only participants can read the conversation document
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Anyone signed in can create a conversation (initial creation)
      allow create: if isSignedIn();
      
      // Only participants can update (lastMessage, unreadBy, typing)
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Participants or Admin can delete
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if isSignedIn() && 
                         resource.data.senderId == request.auth.uid;
        allow delete: if isSignedIn() && 
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // REVIEWS COLLECTION (Top-Level)
    // ============================================
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.fromUserId == request.auth.uid || isAdmin());
    }

    // ============================================
    // REPORTS & SYSTEM MESSAGES
    // ============================================

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /system_messages/{messageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /partner_notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
    }
    
    // ============================================
    // POSTS & FEED
    // ============================================

    match /communityPosts/{postId} {
      // Anyone can read posts
      allow read: if true;
      // Any signed in user can create a post
      allow create: if isSignedIn();
      // Only the author or an admin can update/delete their post
      allow update, delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
    }

    match /stories/{storyId} {
      // Anyone can read stories
      allow read: if true;
      // Any signed in user can create a story
      allow create: if isSignedIn();
      // Only the author or an admin can update/delete their story
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.authorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // DYNAMIC PRICING (PUBLIC)
    // ============================================

    match /subscriptionPlans/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /creditPacks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // APP CONFIGURATION & SETTINGS
    // ============================================
    
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /global_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // PREMIUM OFFERS (PARTNERS ONLY)
    // ============================================
    
    match /offers/{offerId} {
      allow read: if true;
      
      // Create: Must be partner, and partnerId must match their UID
      allow create: if isPartner() && 
                       request.resource.data.partnerId == request.auth.uid;
      
      // Update: Must be partner, own the offer, and cannot modify protected fields
      allow update: if isPartner() && 
                       resource.data.partnerId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['platform_commission', 'global_status']);
      
      // Delete: Partners can delete their own offers, and admins can delete any offer
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /active_offers/{offerId} {
      allow read: if true;
      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /special_offers/{offerId} {
      allow read: if true;
      allow create: if isPartner();
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }
    
    // ============================================
    // FINAL SECURITY: DENY ALL OTHER COLLECTIONS
    // ============================================
    
    match /{document=**} {
      allow read, write: if isAdmin(); // Only admins can access undefined collections
    }
  }
}
