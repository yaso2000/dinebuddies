rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.admin == true ||
              request.auth.token.role == 'admin' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Matches client AdminRoute + adminAccess: panel roles OR known admin emails/UID (Firestore role may still be "user").
    function isAdminOrPanelStaff() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.uid == 'xTgHC1v00LZIZ6ESA9YGjGU5zW33' ||
        (request.auth.token.email != null &&
          request.auth.token.email.matches('(?i)^(admin@dinebuddies\\.com|yaser@dinebuddies\\.com|info@dinebuddies\\.com\\.au|y\\.abohamed@gmail\\.com)$')) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'moderator', 'support', 'staff']
        )
      );
    }

    // Super owner check via Custom Claims only (no hardcoded emails or UIDs).
    // Grant via: admin.auth().setCustomUserClaims(uid, { superOwner: true })
    function isSuperOwner() {
      return isSignedIn() && request.auth.token.superOwner == true;
    }

    // Moderation / sensitive reads: Firestore `users/{uid}.role == 'admin'` or super-owner claim only.
    function isAdminModeration() {
      return isSuperOwner() ||
             (isSignedIn() &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
    }

    // Business accounts (role 'business'); legacy 'partner' kept for backward compatibility
    function isPartner() {
      return isSignedIn() &&
             (request.auth.token.partner == true ||
              request.auth.token.role == 'business' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'business' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner');
    }

    function communityOwnerDoc(partnerId) {
      return exists(/databases/$(database)/documents/users/$(partnerId))
        ? get(/databases/$(database)/documents/users/$(partnerId))
        : get(/databases/$(database)/documents/restaurants/$(partnerId));
    }

    function isCommunityMember(partnerId) {
      let me = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let joined = me.get('joinedCommunities', []);
      let partnerSnap = communityOwnerDoc(partnerId);
      let partner = partnerSnap.data;
      let members = partner.get('communityMembers', []);
      let blocked = partner.get('communityBlockedUserIds', []);
      return (request.auth.uid == partnerId ||
             request.auth.uid in members ||
             partnerId in joined) &&
             !(request.auth.uid in blocked);
    }

    function isCommunityChatMuted(partnerId) {
      let partner = communityOwnerDoc(partnerId).data;
      let muted = partner.get('communityMutedUserIds', []);
      return request.auth.uid in muted;
    }

    function canWriteCommunityChat(partnerId) {
      return (isCommunityMember(partnerId) || isAdmin()) &&
             (request.auth.uid == partnerId || !isCommunityChatMuted(partnerId));
    }

    function isCommunityChatDisplay(partnerId) {
      return isSignedIn() &&
             request.auth.token.get('communityDisplay', false) == true &&
             request.auth.token.get('communityDisplayPartnerId', '') == partnerId;
    }

    function canReadCommunityChat(partnerId) {
      return isAdmin() ||
             isCommunityChatDisplay(partnerId) ||
             (isSignedIn() &&
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              isCommunityMember(partnerId));
    }

    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return request.auth.uid in chat.participants;
    }
    
    // Invitation chat: only host or joined participants (public invitations)
    function isPublicInvitationChatParticipant(invitationId) {
      let inv = get(/databases/$(database)/documents/invitations/$(invitationId)).data;
      let isHost = inv.get(['author', 'id'], '') == request.auth.uid || inv.get('authorId', '') == request.auth.uid;
      let joined = inv.get('joined', []);
      let isJoined = request.auth.uid in joined;
      return isHost || isJoined;
    }
    
    // Invitation chat: only host or accepted invitees (private invitations).
    // LEGACY-DATA RISK: If rsvps is missing or a user has no rsvps entry, they will be denied;
    // ensure the app sets rsvps when users accept, and consider migrating old docs if needed.
    function isPrivateInvitationHost(data) {
      return data.authorId == request.auth.uid ||
             (data.author is map && data.author.get('id', '') == request.auth.uid);
    }

    function isUidInPrivateInviteList(invited) {
      return invited is list && request.auth.uid in invited;
    }

    function hasPrivateInvitationRsvp(data) {
      let rsvps = data.get('rsvps', {});
      return rsvps is map && rsvps.get(request.auth.uid, null) != null;
    }

    function canReadPrivateInvitationDoc(data) {
      return isAdminOrPanelStaff() ||
             isPrivateInvitationHost(data) ||
             isUidInPrivateInviteList(data.get('invitedFriends', [])) ||
             hasPrivateInvitationRsvp(data);
    }

    // List queries: only host + invitedFriends branches (must match client where() filters).
    // Do NOT add hasPrivateInvitationRsvp or isAdminOrPanelStaff here — Firestore rejects the query.

    function isPrivateInvitationChatParticipant(invitationId) {
      let inv = get(/databases/$(database)/documents/private_invitations/$(invitationId)).data;
      let isHost = isPrivateInvitationHost(inv);
      let invited = isUidInPrivateInviteList(inv.get('invitedFriends', []));
      let rsvps = inv.get('rsvps', {});
      let accepted = rsvps is map && rsvps.get(request.auth.uid, null) == 'accepted';
      return isHost || (invited && accepted);
    }

    function isSocialInvitationChatParticipant(invitationId) {
      let inv = get(/databases/$(database)/documents/social_invitations/$(invitationId)).data;
      let isHost = isPrivateInvitationHost(inv);
      let invited = isUidInPrivateInviteList(inv.get('invitedFriends', []));
      let rsvps = inv.get('rsvps', {});
      let accepted = rsvps is map && rsvps.get(request.auth.uid, null) == 'accepted';
      return isHost || (invited && accepted);
    }

    // Invited guests may post (e.g. RSVP apology before/after respond); read stays accepted-only.
    function canPostPrivateInvitationMessage(invitationId) {
      let inv = get(/databases/$(database)/documents/private_invitations/$(invitationId)).data;
      return isPrivateInvitationHost(inv) ||
             isUidInPrivateInviteList(inv.get('invitedFriends', []));
    }

    function canPostSocialInvitationMessage(invitationId) {
      let inv = get(/databases/$(database)/documents/social_invitations/$(invitationId)).data;
      return isPrivateInvitationHost(inv) ||
             isUidInPrivateInviteList(inv.get('invitedFriends', []));
    }

    function deliveredToAppendOnlyByViewer() {
      let before = resource.data.get('deliveredTo', []);
      let after = request.resource.data.get('deliveredTo', before);
      return after is list &&
             after.hasAll(before) &&
             after.hasOnly(before.concat([request.auth.uid]));
    }

    function readByAppendOnlyByViewer() {
      let before = resource.data.get('readBy', []);
      let after = request.resource.data.get('readBy', before);
      return after is list &&
             after.hasAll(before) &&
             after.hasOnly(before.concat([request.auth.uid]));
    }

    function isReceiptFieldsOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deliveredTo', 'readBy']) &&
             deliveredToAppendOnlyByViewer() &&
             readByAppendOnlyByViewer();
    }

    // True when Firestore doc has never stored `role` (e.g. email-only stub from auth sync).
    // Allows the first write that sets role to business during /business/signup — without allowing
    // consumer accounts (role == 'user') to change role via client (those docs always have role set).
    function userDocHasNoRoleField() {
      return !resource.data.keys().hasAny(['role']);
    }

    // Mid-flow business signup (step 1) may have registrationIntent:business but role accidentally set to
    // 'user' (race with profile bootstrap). Allow one completion write to role:business + businessInfo.
    function isBusinessSignupCompletionFromIntent() {
      return resource.data.get('registrationIntent', '') == 'business' &&
             (request.resource.data.role == 'business' || request.resource.data.role == 'partner') &&
             request.resource.data.keys().hasAny(['businessInfo']);
    }

    // True when users/{uid} has no real businessInfo yet (empty or missing). Used so /business/signup can
    // replace a consumer stub (e.g. role:user from a race) with partner + businessInfo in one setDoc.
    function hasMeaningfulBusinessInfo() {
      return resource.data.keys().hasAny(['businessInfo']) &&
             resource.data.businessInfo is map &&
             resource.data.businessInfo.keys().size() > 0;
    }

    function isUpgradingStubToBusinessProfile() {
      return !hasMeaningfulBusinessInfo() &&
             (request.resource.data.role == 'business' || request.resource.data.role == 'partner') &&
             request.resource.data.keys().hasAny(['businessInfo']);
    }

    // Affiliate / referral: financial and identity fields are written only by Cloud Functions (Admin SDK).
    function affiliateServerOnlyUserKeys() {
      return [
        'current_balance', 'total_earned', 'pending_referrals_count', 'successful_referrals_count',
        'pending_payouts', 'total_clicks', 'referral_code', 'referral_link', 'affiliateLastCommissionSessionId',
        'registrationChannel'
      ];
    }

    // Affiliate agents may edit contact/payout identity fields only (not balances or referral codes).
    function affiliateAgentContactFieldsOnlyUpdate(userId) {
      return isOwner(userId) &&
             resource.data.get('role', '') == 'affiliate_agent' &&
             request.resource.data.get('role', '') == resource.data.get('role', '') &&
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly([
                 'affiliate_phone', 'affiliate_paypal_email', 'affiliate_address',
                 'affiliate_country', 'affiliate_city'
               ]);
    }

    function userCreateHasNoServerAffiliateFields() {
      return !request.resource.data.keys().hasAny(affiliateServerOnlyUserKeys());
    }

    function userCreateReferredByOk() {
      return !request.resource.data.keys().hasAny(['referred_by']) ||
        (request.resource.data.referred_by is string &&
         request.resource.data.referred_by.matches('^AGENT-[A-Z0-9]{5,12}$'));
    }

    function affiliateServerOnlyKeysAffected() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(affiliateServerOnlyUserKeys());
    }

    // referred_by may be set once (e.g. from sessionStorage at signup); never changed or cleared by client.
    function referredByClientUpdateOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['referred_by']) ||
        (!resource.data.keys().hasAny(['referred_by']) &&
         request.resource.data.referred_by is string &&
         request.resource.data.referred_by.matches('^AGENT-[A-Z0-9]{5,12}$'));
    }

    function ownerAffiliateWriteGuards() {
      return !affiliateServerOnlyKeysAffected() && referredByClientUpdateOk();
    }

    // Clients cannot self-assign affiliate_agent (or staff/admin) on first create — use Cloud Function.
    function userCreateRoleOkForClient() {
      return !request.resource.data.keys().hasAny(['role']) ||
        request.resource.data.role in ['user', 'guest', 'business', 'partner'];
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // Restricted to signed-in users only. Public data should be read from public_profiles.
      allow get: if isSignedIn();
      // Admins can list up to 200; signed-in users can list up to 500 (needed for search feature)
      allow list: if isAdmin() && request.query.limit != null && request.query.limit <= 200;
      allow list: if isAdminOrPanelStaff() && request.query.limit != null && request.query.limit <= 200;
      allow list: if isSignedIn() && request.query.limit != null && request.query.limit <= 500;
      allow create: if isSignedIn() && request.auth.uid == userId &&
                       userCreateHasNoServerAffiliateFields() &&
                       userCreateReferredByOk() &&
                       userCreateRoleOkForClient();
      // Allow user to update their own FCM push tokens (from notificationService)
      allow update: if isOwner(userId) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmTokens']);
      // Affiliate: phone / PayPal / mailing address only (no financial fields)
      allow update: if affiliateAgentContactFieldsOnlyUpdate(userId);
      // First-time personal registration: auth sync may create a role-less stub first, then profile bootstrap sets role:user.
      allow update: if isOwner(userId) &&
                       ownerAffiliateWriteGuards() &&
                       userDocHasNoRoleField() &&
                       request.resource.data.role == 'user';
      // First-time business registration: stub doc has no `role` yet; app sets role + businessInfo together.
      allow update: if isOwner(userId) &&
                       ownerAffiliateWriteGuards() &&
                       userDocHasNoRoleField() &&
                       (request.resource.data.role == 'business' || request.resource.data.role == 'partner') &&
                       request.resource.data.keys().hasAny(['businessInfo']);
      // Same completion when stub was corrupted with role:user before step 2 (see isBusinessSignupCompletionFromIntent)
      allow update: if isOwner(userId) && ownerAffiliateWriteGuards() && isBusinessSignupCompletionFromIntent();
      // Consumer or email-only stub → full business profile (BusinessSignup setDoc after createUser)
      allow update: if isOwner(userId) && ownerAffiliateWriteGuards() && isUpgradingStubToBusinessProfile();
      // Follow / unfollow: owner may update only their following[] list
      allow update: if isOwner(userId) &&
                       ownerAffiliateWriteGuards() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['following']) &&
                       request.resource.data.following is list;
      allow update: if isOwner(userId) && ownerAffiliateWriteGuards() &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['role', 'accountType']);
      // Admin panel (admin + moderator/support/staff): credits, moderation, etc.
      allow update: if isAdminOrPanelStaff();
      // Allow any signed-in user to increment profile engagement counters only (views, likes, shares)
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['businessInfo']) &&
                       request.resource.data.get('businessInfo', {}).diff(resource.data.get('businessInfo', {})).affectedKeys()
                         .hasOnly(['profileViews', 'profileLikes', 'profileShares', 'totalInvitations']);
      // Follow / unfollow: any signed-in user may bump followersCount by ±1 only
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) &&
                       (
                         request.resource.data.followersCount == resource.data.get('followersCount', 0) + 1 ||
                         request.resource.data.followersCount == resource.data.get('followersCount', 0) - 1
                       );
      
      // SUPER OWNER PROTECTION:
      // 1. Only Super Owner can delete Admins.
      // 2. Admins cannot delete themselves.
      // 3. Admins can delete regular users.
      // 4. Regular users can delete themselves (user, business, staff, support - not admin).
      // 5. Owner can delete own doc even if it no longer exists (no-op retry after re-auth).
      
      allow delete: if
        // Case 0: Doc doesn't exist - allow owner no-op (retry after re-auth)
        (isOwner(userId) && !exists(/databases/$(database)/documents/users/$(userId))) ||
        // Case 1: Super Owner (granted via Custom Claim superOwner:true) can delete ANYONE
        isSuperOwner() ||
        // Case 2: Admin deleting a non-admin user
        (isAdmin() && resource.data.get('role', 'user') != 'admin') ||
        // Case 3: Regular user deleting themselves (role must not be admin)
        (isOwner(userId) && resource.data.get('role', 'user') != 'admin');
      
      // Push registration diagnostics (iOS PWA debugging — owner write only)
      match /pushRegistrationLogs/{logId} {
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['step', 'ok', 'at'])
          && request.resource.data.step is string
          && request.resource.data.ok is bool
          && request.resource.data.at == request.time;
        allow read: if isOwner(userId) || isAdminOrPanelStaff();
      }

      // Invite card dismissals (view / decline — hide card permanently for this user)
      match /invite_inbox_dismissals/{invitationId} {
        allow read, write: if isOwner(userId);
      }

      // Read-only invitation history (Cloud Functions write on archive)
      match /invitation_archives/{archiveId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdminOrPanelStaff());
        allow create, update, delete: if false;
      }

      // USER REVIEWS SUBCOLLECTION
      match /reviews/{reviewId} {
        // Anyone can read reviews
        allow read: if true;
        
        // Only signed-in users can create reviews
        allow create: if isSignedIn() && 
                         request.resource.data.fromUserId == request.auth.uid;
        
        // Only review author can update/delete their review
        allow update, delete: if isSignedIn() && 
                                 resource.data.fromUserId == request.auth.uid;
      }
      
      // USER PREFERENCES SUBCOLLECTION
      match /preferences/{docId} {
        // User can read their own preferences
        allow read: if isOwner(userId);
        
        // User can create/update their own preferences
        allow create, update: if isOwner(userId);
        
        // User can delete their own preferences
        allow delete: if isOwner(userId);
      }

      // Affiliate commission ledger (written only by Cloud Functions / Admin SDK)
      match /commissions_history/{entryId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }
    }

    // ============================================
    // WELCOME GIFT CLAIMS (one doc per email key — client createUserProfile)
    // ============================================
    match /welcome_gifts_claimed/{claimId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ============================================
    // BUSINESS LIKES (like system: businessLikes/{businessId}_{userId})
    // ============================================
    match /businessLikes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.businessId is string;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.businessId is string;
    }
    
    // ============================================
    // PUBLIC PROFILES (READ-ONLY PROJECTION)
    // ============================================

    match /public_profiles/{uid} {
      // Public-facing display/search projection
      allow get: if true;
      allow list: if request.query.limit != null && request.query.limit <= 200;

      // Backend-synced only (Cloud Functions trigger/callables)
      allow create, update, delete: if false;
    }

    // ============================================
    // INVITATIONS COLLECTION
    // ============================================
    
    match /invitations/{invitationId} {
      allow read: if true; // Allow public read
      
      allow create: if isSignedIn() && 
                       request.resource.data.author.id == request.auth.uid;
      
      // Host can update
      allow update: if isSignedIn() && 
                       resource.data.author.id == request.auth.uid;
      
      // Users can add themselves to requests (JOIN REQUEST)
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       request.resource.data.requests.hasAll(resource.data.requests) &&
                       request.resource.data.requests.hasOnly([request.auth.uid].concat(resource.data.requests));
      
      // Users can remove themselves from requests
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['requests']) &&
                       resource.data.requests.hasAll(request.resource.data.requests);
      
      allow update: if isAdminOrPanelStaff();
      
      allow delete: if isSignedIn() && 
                       (resource.data.author.id == request.auth.uid || isAdminOrPanelStaff());
      
      // MESSAGES SUBCOLLECTION (Community Chat) — only host or joined participants
      match /messages/{messageId} {
        allow read: if isSignedIn() && isPublicInvitationChatParticipant(invitationId);
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         isPublicInvitationChatParticipant(invitationId);
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
                         isPublicInvitationChatParticipant(invitationId) &&
                         isReceiptFieldsOnlyUpdate();
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // PUBLIC INVITATION ARCHIVES (read-only history; Cloud Functions only write)
    // ============================================

    match /invitation_archives/{archiveId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ============================================
    // PRIVATE INVITATIONS COLLECTION (separate from public)
    // ============================================

    match /private_invitations/{invitationId} {
      // Single-doc reads: host, invitees, RSVP holders, or admin-panel staff
      allow get: if isSignedIn() && canReadPrivateInvitationDoc(resource.data);
      // Collection queries must mirror where() filters exactly (no get() / extra OR branches).
      allow list: if isSignedIn() && (
        resource.data.get('authorId', '') == request.auth.uid ||
        request.auth.uid in resource.data.get('invitedFriends', [])
      );

      // Any signed-in user can create (author must be self)
      allow create: if isSignedIn() &&
                       (request.resource.data.authorId == request.auth.uid ||
                        (request.resource.data.author is map &&
                         request.resource.data.author.get('id', '') == request.auth.uid));

      // Host can update freely; invited friends can update only their RSVP
      allow update: if isSignedIn() &&
                       (isPrivateInvitationHost(resource.data) ||
                        (isUidInPrivateInviteList(resource.data.get('invitedFriends', [])) &&
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['rsvps', 'updatedAt']) &&
                         request.resource.data.rsvps
                           .diff(resource.data.get('rsvps', {}))
                           .affectedKeys()
                           .hasOnly([request.auth.uid])));

      // Only host or admin-panel staff can delete
      allow delete: if isSignedIn() &&
                       (isPrivateInvitationHost(resource.data) || isAdminOrPanelStaff());

      // MESSAGES SUBCOLLECTION (Private Group Chat) — only host or accepted invitees
      match /messages/{messageId} {
        allow read: if isSignedIn() && isPrivateInvitationChatParticipant(invitationId);
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         canPostPrivateInvitationMessage(invitationId);
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
                         isPrivateInvitationChatParticipant(invitationId) &&
                         isReceiptFieldsOnlyUpdate();
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdminOrPanelStaff());
      }
    }

    // ============================================
    // SOCIAL + PERSONAL INVITATIONS (hosted invites — social & 1-on-1)
    // Client writes here via addHostedInvitation / persistPrivateInvitationEditorDraft.
    // Legacy docs may still exist in private_invitations above.
    // ============================================

    match /social_invitations/{invitationId} {
      allow get: if isSignedIn() && canReadPrivateInvitationDoc(resource.data);
      allow list: if isSignedIn() && (
        resource.data.get('authorId', '') == request.auth.uid ||
        request.auth.uid in resource.data.get('invitedFriends', [])
      );

      allow create: if isSignedIn() &&
                       (request.resource.data.authorId == request.auth.uid ||
                        (request.resource.data.author is map &&
                         request.resource.data.author.get('id', '') == request.auth.uid));

      allow update: if isSignedIn() &&
                       (isPrivateInvitationHost(resource.data) ||
                        (isUidInPrivateInviteList(resource.data.get('invitedFriends', [])) &&
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['rsvps', 'updatedAt']) &&
                         request.resource.data.rsvps
                           .diff(resource.data.get('rsvps', {}))
                           .affectedKeys()
                           .hasOnly([request.auth.uid])));

      allow delete: if isSignedIn() &&
                       (isPrivateInvitationHost(resource.data) || isAdminOrPanelStaff());

      match /messages/{messageId} {
        allow read: if isSignedIn() && isSocialInvitationChatParticipant(invitationId);
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         canPostSocialInvitationMessage(invitationId);
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
                         isSocialInvitationChatParticipant(invitationId) &&
                         isReceiptFieldsOnlyUpdate();
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid || isAdminOrPanelStaff());
      }
    }

    // ============================================
    // CHATS COLLECTION (Group Chats)
    // ============================================

    
    match /chats/{chatId} {
      // Only chat participants or admins
      allow read: if isSignedIn() &&
                    (request.auth.uid in resource.data.participants || isAdmin());
      
      // Creator must be a participant
      allow create: if isSignedIn() &&
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants/admin can update
      allow update: if isSignedIn() &&
                      (request.auth.uid in resource.data.participants || isAdmin());
      
      // Only admin can delete
      allow delete: if isAdmin();
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Only chat participants/admin can read messages
        allow read: if isSignedIn() && (isChatParticipant(chatId) || isAdmin());
        
        // Sender must be a participant/admin
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid &&
                         (isChatParticipant(chatId) || isAdmin());
        
        // Sender can update their own message
        allow update: if isSignedIn() && 
                         isOwner(resource.data.senderId);
        
        // Sender or admin can delete message
        allow delete: if isSignedIn() && 
                         (isOwner(resource.data.senderId) || isAdmin());
      }
    }
    
    // ============================================
    // CONVERSATIONS COLLECTION (1-on-1 Chats)
    // ============================================
    
    match /conversations/{conversationId} {
      // getDoc on missing doc has resource == null — must allow before checking fields.
      allow get: if isSignedIn() && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Security: enforce strict 1:1 participant shape to prevent forged conversation graphs
      allow create: if isSignedIn() &&
                      request.resource.data.participants is list &&
                      request.resource.data.participants.size() == 2 &&
                      request.auth.uid in request.resource.data.participants;
      
      // Only participants can update (lastMessage, unreadBy, typing)
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Participants or Admin can delete
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // Security: constrain message create schema and sender ownership
        allow create: if isSignedIn() && 
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.keys().hasOnly(['senderId', 'text', 'type', 'createdAt', 'status', 'deliveredTo', 'readBy', 'reactions', 'replyTo', 'audioUrl', 'imageUrl', 'fileUrl', 'duration', 'sharedContent']) &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if isSignedIn() && 
                         resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
                         isReceiptFieldsOnlyUpdate();
        allow delete: if isSignedIn() && 
                         (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // ============================================
    // REVIEWS COLLECTION (Top-Level)
    // ============================================
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // REPORTS & SYSTEM MESSAGES
    // ============================================

    match /reports/{reportId} {
      allow read: if isAdminModeration();
      // Security: bind report ownership/status to authenticated reporter
      allow create: if isSignedIn() &&
                      request.resource.data.reporterId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update, delete: if isAdminModeration();
    }

    match /system_messages/{messageId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /partner_notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
      // Client-side create is self-only; cross-user partner notifications must use trusted backend callable, unless it's a feedback alert.
      allow create: if (isSignedIn() &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.restaurantId == request.auth.uid) ||
                      (request.resource.data.type == 'business_feedback');
      allow update, delete: if isSignedIn() && (resource.data.restaurantId == request.auth.uid || isAdmin());
    }
    
    // ============================================
    // POSTS & FEED
    // ============================================


    match /communityPosts/{postId} {
      // Anyone can read posts
      allow read: if true;
      // Any signed in user can create a post
      allow create: if isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.authorId == request.auth.uid ||
          request.resource.data.partnerId == request.auth.uid ||
          (request.resource.data.author != null &&
           request.resource.data.author.id == request.auth.uid)
        );
      // Only the author or an admin can update/delete their post
      allow update, delete: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
      // Any signed-in user can like, repost, or comment (social interactions only)
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'reposts', 'comments']);
    }

    match /stories/{storyId} {
      // Anyone can read stories
      allow read: if true;
      // Security: enforce ownership on story creation (prevent impersonation)
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || 
        request.resource.data.authorId == request.auth.uid ||
        request.resource.data.partnerId == request.auth.uid ||
        (request.resource.data.author != null && request.resource.data.author.id == request.auth.uid)
      );
      // Only the author or an admin can fully update/delete their story
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.authorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.author != null && resource.data.author.id == request.auth.uid) ||
        isAdmin()
      );
      // Any signed-in user can add their reaction / like / view (append-only fields)
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'likes', 'views']);
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Client-side create is limited to self-only notifications to block cross-user spoofing.
      // Cross-user/system notifications must be created via trusted backend callables.
      allow create: if isSignedIn() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ============================================
    // DYNAMIC PRICING (PUBLIC)
    // ============================================

    match /subscriptionPlans/{docId} {
      allow read: if true;
      allow write: if isAdminOrPanelStaff();
    }

    match /creditPacks/{docId} {
      allow read: if true;
      allow write: if isAdminOrPanelStaff();
    }

    // ============================================
    // APP CONFIGURATION & SETTINGS
    // ============================================
    
    match /admin_announcements/{docId} {
      allow read: if isAdminOrPanelStaff();
      allow create, update, delete: if false;
    }

    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /global_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // PREMIUM OFFERS (PARTNERS ONLY)
    // ============================================
    
    match /offers/{offerId} {
      allow read: if true;
      
      // Create: Must be partner, and partnerId must match their UID
      allow create: if isPartner() && 
                       request.resource.data.partnerId == request.auth.uid;
      
      // Update: Must be partner, own the offer, and cannot modify protected fields
      allow update: if isPartner() && 
                       resource.data.partnerId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['platform_commission', 'global_status']);
      
      // Delete: Partners can delete their own offers, and admins can delete any offer
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /active_offers/{offerId} {
      allow read: if true;
      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }

    match /special_offers/{offerId} {
      allow read: if true;
      // Security: bind created special offer to authenticated partner owner
      allow create: if isPartner() && request.resource.data.partnerId == request.auth.uid;
      allow update: if isPartner() && resource.data.partnerId == request.auth.uid;
      allow delete: if (isPartner() && resource.data.partnerId == request.auth.uid) || isAdmin();
    }
    
    // ============================================
    // COMMUNITIES COLLECTION (Community Chat)
    // ============================================

    match /communities/{partnerId} {
      // Members, display screens (cast), or admins can read community info
      allow read: if canReadCommunityChat(partnerId);

      // Only the partner (owner) can create/update the community document
      allow create, update: if isOwner(partnerId) || isAdmin();
      allow delete: if isAdmin();

      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Members, venue display screens, or admins can read
        allow read: if canReadCommunityChat(partnerId);

        // Only community members/owner/admin can send (muted members cannot post)
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         canWriteCommunityChat(partnerId);

        // Sender can update their own message (edit text, etc.)
        allow update: if isSignedIn() &&
                         resource.data.senderId == request.auth.uid &&
                         canWriteCommunityChat(partnerId);

        // Community members can update reactions only (muted members cannot react)
        allow update: if isSignedIn() &&
                         canWriteCommunityChat(partnerId) &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

        // Readers may append only their own delivery/read receipts
        allow update: if isSignedIn() &&
                         (isCommunityMember(partnerId) || isAdmin()) &&
                         isReceiptFieldsOnlyUpdate();

        // Admin can update anything
        allow update: if isAdmin();

        // Sender, community owner, or admin can delete
        allow delete: if isSignedIn() &&
                         (resource.data.senderId == request.auth.uid ||
                          isOwner(partnerId) ||
                          isAdmin());
      }
    }

    // ============================================
    // FEATURED POSTS (Business Pro elite slides)
    // ============================================
    match /featured_posts/{postId} {
      // Anyone can read (displayed publicly in the home feed)
      allow read: if true;

      // Only the owning partner can create/update/delete their own posts
      allow create: if isSignedIn() &&
                       request.resource.data.partnerId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               (resource.data.partnerId == request.auth.uid || isAdmin());

      // Any signed-in user can like, comment, or repost (social interactions only)
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likes', 'reposts', 'comments']);
    }

    // ============================================
    // BUSINESS FEEDBACK & COMPLAINTS
    // ============================================
    match /business_feedback/{feedbackId} {
      // Only the assigned business owner (or Admin) can read their inbox
      allow read: if isSignedIn() && (resource.data.businessId == request.auth.uid || isAdmin());
      
      // Anyone (even public visitors) can submit feedback/complaints
      allow create: if true;
      
      // Only the business owner (to mark as resolved) or Admin can update
      allow update: if isSignedIn() && (resource.data.businessId == request.auth.uid || isAdmin());
      
      allow delete: if isAdmin();
    }

    // ============================================
    // ADMIN EMAIL CAMPAIGN LOG (server-only via Cloud Functions)
    // ============================================
    match /admin_email_campaigns/{id} {
      allow read, write: if false;
    }

    // ============================================
    // ADMIN CREDIT GRANTS (audit log from Grant credits page)
    // ============================================
    match /admin_credit_grants/{id} {
      allow read, create: if isAdminOrPanelStaff();
      allow update, delete: if false;
    }

    // ============================================
    // CREDIT TRANSACTIONS (admin grants + user ledger)
    // ============================================
    match /credit_transactions/{id} {
      allow read: if isAdminOrPanelStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdminOrPanelStaff() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // Profile gifts (Cloud Functions only — sender/recipient read)
    match /profile_gifts/{giftId} {
      allow read: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // Gift send idempotency locks (Cloud Functions only)
    match /profile_gift_idempotency/{docId} {
      allow read, write: if false;
    }

    // ============================================
    // AFFILIATE PAYOUT REQUESTS (created by Cloud Functions only)
    // ============================================
    match /payout_requests/{id} {
      allow read: if isSignedIn() &&
                     (resource.data.agentUid == request.auth.uid || isAdminOrPanelStaff());
      allow create, update, delete: if false;
    }

    // ============================================
    // AFFILIATE REFERRAL REGISTRY (Cloud Functions Admin SDK only)
    // ============================================
    match /affiliate_referral_codes/{code} {
      allow read, write: if false;
    }

    // Referral click rate limits (Cloud Functions only)
    match /referral_rate_limits/{docId} {
      allow read, write: if false;
    }

    // ============================================
    // BUSINESS MOTION POSTS (Smart Post Studio)
    // ============================================
    match /business_motion_posts/{postId} {
      // Published posts are public (feed); owners and staff can read drafts too.
      allow read: if resource.data.status == 'published' ||
                     (isSignedIn() && resource.data.ownerId == request.auth.uid) ||
                     isAdminOrPanelStaff();

      allow create: if isPartner() &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.businessId is string &&
                       request.resource.data.status == 'draft';

      allow update: if isSignedIn() &&
                       resource.data.ownerId == request.auth.uid &&
                       request.resource.data.ownerId == resource.data.ownerId &&
                       request.resource.data.businessId == resource.data.businessId &&
                       resource.data.status != 'archived';

      allow delete: if isSignedIn() &&
                       (resource.data.ownerId == request.auth.uid || isAdminOrPanelStaff());
    }

    // ============================================
    // RESTAURANTS (admin Google imports + claimed ownership)
    // ============================================
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAdminOrPanelStaff();
      allow update: if isAdminOrPanelStaff() ||
                       (isSignedIn() &&
                        resource.data.isClaimed == true &&
                        resource.data.ownerId == request.auth.uid &&
                        request.resource.data.ownerId == request.auth.uid &&
                        request.resource.data.isClaimed == true) ||
                       (isSignedIn() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['businessInfo']) &&
                        request.resource.data.get('businessInfo', {}).diff(resource.data.get('businessInfo', {})).affectedKeys()
                          .hasOnly(['profileViews', 'profileLikes', 'profileShares', 'totalInvitations']));
      allow delete: if isAdminOrPanelStaff();
    }

    // Discovery feed profile likes ("Liked You" source data)
    match /discovery_likes/{likeId} {
      // getDoc on a missing doc has resource == null — must allow before checking fields.
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.likerId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow list: if false;
      allow create: if isSignedIn() &&
        request.resource.data.likerId == request.auth.uid &&
        request.resource.data.targetUserId is string &&
        request.resource.data.targetUserId != request.auth.uid &&
        request.resource.data.keys().hasAll(['targetUserId', 'likerId', 'createdAt', 'mutual']) &&
        request.resource.data.mutual is bool;
      // Match completion: the second liker may flip mutual on the existing reverse doc.
      allow update: if isSignedIn() && (
        (
          resource.data.targetUserId == request.auth.uid &&
          resource.data.mutual != true &&
          request.resource.data.mutual == true &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mutual'])
        ) ||
        (
          resource.data.mutual == true &&
          request.resource.data.mutual == false &&
          (request.auth.uid == resource.data.likerId || request.auth.uid == resource.data.targetUserId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mutual'])
        )
      );
      allow delete: if isSignedIn() && resource.data.likerId == request.auth.uid;
    }

    // Discovery wave greetings — one per sender→target per UTC day (doc id includes dayKey)
    match /discovery_greetings/{greetingId} {
      allow get: if isSignedIn() && (
        resource == null ||
        resource.data.senderId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow list: if false;
      allow create: if isSignedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.targetUserId is string &&
        request.resource.data.targetUserId != request.auth.uid &&
        request.resource.data.dayKey is string &&
        request.resource.data.keys().hasAll(['targetUserId', 'senderId', 'createdAt', 'dayKey']);
      allow update, delete: if false;
    }

    // Follow / like refollow cooldown — 24h after unfollow or unlike
    match /connection_action_cooldowns/{docId} {
      allow get: if isSignedIn() &&
        resource.data.viewerId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() &&
        request.resource.data.viewerId == request.auth.uid &&
        request.resource.data.targetId is string &&
        request.resource.data.targetId != request.auth.uid &&
        request.resource.data.keys().hasAll(['viewerId', 'targetId']);
      allow update: if isSignedIn() &&
        resource.data.viewerId == request.auth.uid &&
        request.resource.data.viewerId == request.auth.uid &&
        request.resource.data.targetId == resource.data.targetId;
      allow delete: if false;
    }

    // ============================================
    // FINAL SECURITY: DENY ALL OTHER COLLECTIONS
    // ============================================
    
    match /{document=**} {
      allow read, write: if isAdmin(); // Only admins can access undefined collections
    }
  }
}
