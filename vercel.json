{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "installCommand": "npm install",
    "rewrites": [
        {
            "source": "/__/auth/:path*",
            "destination": "https://dinebuddies.firebaseapp.com/__/auth/:path*"
        },
        {
            "source": "/__/firebase-config",
            "destination": "https://dinebuddies.firebaseapp.com/__/firebase-config"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "build": {
        "env": {
            "NODE_OPTIONS": "--max_old_space_size=4096"
        }
    }
}