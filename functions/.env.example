# Copy to functions/.env — Firebase CLI loads this on deploy (not the repo root .env).
# After editing: firebase deploy --only functions

RESEND_API_KEY=re_xxxxxxxx
PUBLIC_APP_ORIGIN=https://www.dinebuddies.com

# ── Stripe ────────────────────────────────────────────────────────────────
# Test: STRIPE_MODE=test + sk_test_… + test price IDs + test webhook secret
# Live: STRIPE_MODE=live + sk_live_… + live price IDs + live webhook secret
# Use Standard secret key (sk_…), NOT restricted (rk_…).
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

STRIPE_PRICE_CREDITS_200=price_xxxxxxxx
STRIPE_PRICE_CREDITS_500=price_xxxxxxxx
STRIPE_PRICE_CREDITS_1000=price_xxxxxxxx
STRIPE_PRICE_CREDITS_3000=price_xxxxxxxx
STRIPE_PRICE_BUSINESS_MONTHLY=price_xxxxxxxx

# Live webhook (Test mode OFF in dashboard → Developers → Webhooks):
#   URL: https://us-central1-PROJECT.cloudfunctions.net/stripeWebhook
# Events: checkout.session.completed, customer.subscription.*, invoice.payment_*

# ── PayPal (one-time checkout for Dine Credits) ─────────────────────────────
# Developer Dashboard → Apps & Credentials
# Use sandbox first, then switch PAYPAL_MODE=live with live credentials.
# Currency can stay USD or match your PayPal merchant setup.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_CURRENCY=USD
# Paid Business monthly (PayPal one-time checkout; format 29.00)
PAYPAL_BUSINESS_MONTHLY_PRICE=29.00

# ── Google Play (Android in-app billing) ───────────────────────────────────
# Play Console → Setup → API access → link Firebase / service account
# Create consumable products (same credits as Stripe packs):
#   dine_credits_200, dine_credits_500, dine_credits_1000, dine_credits_3000
GOOGLE_PLAY_PACKAGE_NAME=com.dinebuddies.app
# Minified JSON of Play Console service account (single line):
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Gemini (demo user personas + optional AI features) ────────────────────
# Google AI Studio → API key
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_VERTEX_LOCATION=us-central1

# ── Imagen (admin demo user AI avatar/cover via Vertex) ─────────────────────
# IMAGEN_MODEL=imagen-4.0-fast-generate-001
