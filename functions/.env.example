# Copy to .env in this folder (functions/.env) — NOT only the repo root .env.
# Firebase CLI reads functions/.env when you deploy and injects these into Cloud Functions.
# Without RESEND_API_KEY here (or in Cloud Console → Function env), verification emails will not send.

RESEND_API_KEY=re_xxxxxxxx
# Optional: published template id or alias (default in code: account-verification). Wrong id → inline HTML fallback.
# RESEND_VERIFICATION_TEMPLATE_ID=account-verification
# Used in referral_link on users (affiliate) and email links. Match your production SPA host.
PUBLIC_APP_ORIGIN=https://dinebuddies.com
# Affiliate business checkout uses tiered rates (20% / 25% / 30% by sale index) with integer cents math.
# Sanity cap on tier bps (1–3000). Default 3000 = 30% max.
# AFFILIATE_MAX_COMMISSION_BPS=3000

# Stripe — Dine Credits wallet (one-time prices). Copy these lines into functions/.env before deploy.
# Mapping assumed: 3000 → 1000 → 500 → 200 credits (same order as your Stripe product list). If checkout
# shows the wrong amount, swap IDs to match each product’s Price in the Dashboard.
STRIPE_PRICE_CREDITS_3000=price_1TQdMyKpQn3RDJUCQrz68eXO
STRIPE_PRICE_CREDITS_1000=price_1TQd3XKpQn3RDJUCeYYVV6Ff
STRIPE_PRICE_CREDITS_500=price_1TQd1kKpQn3RDJUC3gkKoZsw
STRIPE_PRICE_CREDITS_200=price_1TQd1JKpQn3RDJUC4hZlhLfR

# Webhook signing secret (Developers → Webhooks → your endpoint → Signing secret).
# Without this, checkout.session.completed is rejected and credits are not granted until you use the in-app fallback
# or configure the webhook. The app now also calls fulfillDineCreditsCheckout after redirect.
# STRIPE_WEBHOOK_SECRET=whsec_...
