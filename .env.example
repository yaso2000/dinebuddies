# Firebase Configuration
# Copy this file to .env and replace placeholders with your actual values
# Get values from: Firebase Console > Project Settings > General > Your apps > SDK setup
# NEVER commit .env to version control
#
# Email/password for users & business: Firebase Console → Authentication → Sign-in method
# → enable "Email/Password".
#
# Email verification UX: set each template’s "Action URL" to your app handler, e.g.
#   https://your-domain.com/auth/action
# (and for local dev: http://localhost:PORT/auth/action). Same path must exist in this app (Route /auth/action).
# Optional: force email links to use production origin while testing multiple environments:
# VITE_PUBLIC_APP_URL=https://your-domain.com
#
# Custom "From" address (not noreply@firebase): Firebase’s built-in sender cannot be fully replaced from the client.
# Use Identity Platform custom SMTP, or Cloud Functions + admin.auth().generateEmailVerificationLink() + SendGrid/Resend.

VITE_FIREBASE_API_KEY=your-api-key-here
# Use Firebase default auth domain only ({VITE_FIREBASE_PROJECT_ID}.firebaseapp.com).
# Apple Return URL is registered there — do NOT set www.your-domain.com (VITE_FIREBASE_AUTH_DOMAIN is ignored).
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Web Push (FCM) — required for iPhone/Android push notifications
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
# Must also be set in Vercel/hosting env as VITE_FIREBASE_VAPID_KEY (production builds fail silently without it)
VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-key-here

# Google Sign-In uses Firebase Console → Authentication → Google (default Web OAuth client).
# Do NOT set VITE_GOOGLE_WEB_CLIENT_ID — overriding client_id in code causes auth/argument-error.
# If you see redirect_uri_mismatch, fix Authorized redirect URIs in Google Cloud Console:
#   APIs & Services > Credentials > your OAuth 2.0 Client ID (type: Web application)
#   Authorized redirect URIs MUST include (replace PROJECT_ID with VITE_FIREBASE_PROJECT_ID):
#     https://PROJECT_ID.firebaseapp.com/__/auth/handler
#     https://PROJECT_ID.web.app/__/auth/handler
#   Authorized JavaScript origins MUST include every site URL you use, e.g.:
#     https://your-real-domain.com
#     https://www.your-real-domain.com
#     http://localhost:5176   (default Vite port in vite.config.js — match your dev server)
# Also: Firebase Console > Authentication > Settings > Authorized domains — add your custom domain (no https).
# VITE_GOOGLE_WEB_CLIENT_ID is deprecated and ignored by the app.
# Cursor / VS Code embedded preview blocks OAuth popups — set true if Google sign-in still uses popup in the IDE:
# VITE_DEV_EMBEDDED_PREVIEW=true
# Facebook Login: Meta App settings must list your dev/prod origins for the JS SDK.
#
# Sign in with Apple (personal login — button already in the app; enable providers below):
# 1) Apple Developer (developer.apple.com) → Certificates, Identifiers & Profiles → Identifiers
#    a) App ID: enable "Sign In with Apple" for your iOS app (if any).
#    b) Services ID (type: Services IDs): create e.g. com.dinebuddies.web — enable Sign In with Apple.
#       Domains: your-site.com (+ localhost for dev if Apple allows). Return URLs:
#         https://PROJECT_ID.firebaseapp.com/__/auth/handler
#         https://PROJECT_ID.web.app/__/auth/handler
#    c) Keys: create key with "Sign In with Apple" → download .p8 (once).
# 2) Firebase Console → Authentication → Sign-in method → Apple → Enable.
#    Paste Team ID, Key ID, Services ID, upload .p8. OAuth code flow configuration = same Return URL as above.
# 3) Authentication → Settings → Authorized domains: add your production domain (and localhost is allowed by default).
# Until step 2 is done, the Apple button shows auth_apple_not_enabled / operation-not-allowed.

# Google Maps Places API (for location search)
# Get from: Google Cloud Console > APIs & Services > Credentials
# Enable "Places API" and "Maps JavaScript API"
# Local dev: the browser key must allow this origin under HTTP referrers, e.g. http://localhost:5173/* (match your Vite port)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe (client — publishable key only; secrets go in functions/.env)
# Test mode: use pk_test_... and set VITE_STRIPE_TEST_MODE=true (shows test banner + AUD labels)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# VITE_STRIPE_TEST_MODE=true
# Live: pk_live_... (omit VITE_STRIPE_TEST_MODE or set false)
# Price IDs for checkout live in functions/.env (STRIPE_PRICE_*) — see functions/.env.example
#
# PayPal (client)
# Add the client ID here; secrets stay in functions/.env
# VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
# VITE_PAYPAL_CURRENCY=USD
# VITE_PAYPAL_MODE=sandbox
# Optional UI badge when sandbox is active:
# VITE_PAYPAL_TEST_MODE=true

# Firebase Admin (Vercel /api/*) — option A: paste full service account JSON (recommended on Vercel):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
#
# Option B: separate fields from service account JSON download:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@....iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY_ID=abc123def456...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Prefer GOOGLE_APPLICATION_CREDENTIALS=path\to\key.json for local scripts instead of pasting keys.

# AI image generation (/api/ai/multi-generate) — set on Vercel (not only at build time):
# VITE_FIREBASE_API_KEY, VITE_FIREBASE_APP_ID, VITE_FIREBASE_PROJECT_ID (same as web app)
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app  (must match Firebase console)
# IMAGEN_MODEL=imagen-4.0-fast-generate-001  (optional; defaults try 4.0 then 3.0)
#
# Gemini backend (server env on Vercel — default auto retries vertex if Google Prepay is depleted):
#   auto    — try Google AI Studio Prepay first, then Vertex AI (Cloud Billing). Recommended.
#   google  — Prepay only (fails with 429 when AI Studio Prepay balance is $0).
#   vertex  — Vertex only (Blaze + Vertex AI API + Firebase AI Logic API).
# GEMINI_BACKEND=auto
# GEMINI_VERTEX_LOCATION=us-central1

# Optional: public invitation “Optional AI cover” panel — display same per-generation cost as server
# INVITATION_AI_IMAGE_CREDIT_COST (default 5). Must match Vercel /api/generate-image for accurate messaging.
# VITE_INVITATION_AI_IMAGE_CREDIT_COST=5

# Google Places (server) — minimal Place Details for admin virtual business import
# GOOGLE_PLACES_API_KEY= or GOOGLE_MAPS_SERVER_KEY=
# ADMIN_EMAILS=admin@dinebuddies.com,yaser@dinebuddies.com

# Google Business Profile OAuth (business claim verification — separate from Firebase Google sign-in)
# 1) Google Cloud Console → APIs & Services → Enable:
#    - My Business Account Management API
#    - My Business Business Information API
# 2) Create OAuth 2.0 Client ID (Web application)
# 3) Authorized redirect URI (production):
#    https://www.dinebuddies.com/api/business/google-claim/callback
#    (local dev: http://localhost:5176/api/business/google-claim/callback — match Vite port)
# 4) OAuth consent screen → add scope: https://www.googleapis.com/auth/business.manage
# GOOGLE_BUSINESS_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_BUSINESS_OAUTH_CLIENT_SECRET=xxxxxxxx
# GOOGLE_BUSINESS_OAUTH_REDIRECT_URI=https://www.dinebuddies.com/api/business/google-claim/callback

# Business signup phone OTP uses Firebase Phone Authentication (client SDK).
# Enable Phone provider in Firebase Console → Authentication → Sign-in method.
# Optional server reCAPTCHA for other APIs:
# RECAPTCHA_SECRET_KEY=xxxxxxxx
# RECAPTCHA_MIN_SCORE=0.5
# VITE_RECAPTCHA_SITE_KEY=xxxxxxxx
#
# Local `npm run dev`: Vite proxies /api to production unless overridden:
# VITE_DEV_API_PROXY=https://www.dinebuddies.com

# ── Cloud Functions (separate from this file) ───────────────────────────────
# Verification & Resend run in Firebase Functions. Put secrets in functions/.env
# (copy from functions/.env.example). Root .env is for Vite only — it does NOT deploy with Functions.
# After editing functions/.env run: firebase deploy --only functions
