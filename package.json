{
  "name": "invitation-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx --yes serve dist -p 4173",
    "dev:src": "vite",
    "dev:vercel": "node scripts/vercel-cli.mjs dev --local-config vercel-dev.json",
    "dev:network": "vite --host",
    "sync:dating-templates": "node scripts/sync-dating-invitation-templates.mjs",
    "prebuild": "npm run sync:dating-templates",
    "build": "vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('public/firebase-messaging-sw.js','dist/firebase-messaging-sw.js')\"",
    "build:firebase": "node scripts/ensure-maps-key-for-build.mjs && node scripts/sync-dating-invitation-templates.mjs && vite build && node -e \"require('fs').copyFileSync('public/firebase-messaging-sw.js','dist/firebase-messaging-sw.js')\"",
    "vercel-build": "node scripts/vercel-build.mjs",
    "vercel": "node scripts/vercel-cli.mjs",
    "vercel:login": "node scripts/vercel-cli.mjs login",
    "deploy:predist": "node scripts/deploy-vercel.mjs --predist",
    "deploy:vercel": "node scripts/deploy-vercel.mjs",
    "verify:firebase-admin": "node scripts/verify-firebase-admin-env.mjs",
    "set:firebase-admin-env": "node scripts/set-firebase-admin-env-from-json.mjs",
    "minify:service-account": "node scripts/minify-service-account-json.mjs",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:live": "npx --yes serve dist -p 4173",
    "wipe-firebase-user-data": "node scripts/wipe-firebase-user-data.mjs",
    "wipe-firebase-user-data:execute": "node scripts/wipe-firebase-user-data.mjs --execute"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "browser-image-compression": "^2.0.2",
    "country-state-city": "^3.2.1",
    "emoji-picker-react": "^4.18.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lottie-react": "^2.4.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.22.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vercel": "^50.42.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^7.3.1"
  }
}
