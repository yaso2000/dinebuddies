{
  "name": "invitation-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:fresh": "node scripts/kill-vite-dev-ports.mjs && vite",
    "dev:dist": "npx --yes serve dist -p 4173",
    "dev:src": "vite",
    "dev:vercel": "node scripts/vercel-cli.mjs dev --local-config vercel-dev.json",
    "dev:network": "vite --host",
    "sync:private-templates": "node scripts/sync-private-invitation-templates.mjs",
    "sync:community-banner-templates": "node scripts/sync-community-banner-templates.mjs",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "prebuild": "npm run sync:private-templates && npm run sync:community-banner-templates",
    "build": "vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('public/firebase-messaging-sw.js','dist/firebase-messaging-sw.js')\"",
    "build:firebase": "node scripts/ensure-maps-key-for-build.mjs && node scripts/sync-private-invitation-templates.mjs && vite build && node -e \"require('fs').copyFileSync('public/firebase-messaging-sw.js','dist/firebase-messaging-sw.js')\"",
    "vercel-build": "node scripts/vercel-build.mjs",
    "vercel": "node scripts/vercel-cli.mjs",
    "vercel:login": "node scripts/vercel-cli.mjs login",
    "deploy:predist": "node scripts/deploy-vercel.mjs --predist",
    "deploy:vercel": "node scripts/deploy-vercel.mjs",
    "verify:firebase-admin": "node scripts/verify-firebase-admin-env.mjs",
    "firebase:login": "node scripts/firebase-login.mjs",
    "firebase:login:reauth": "node scripts/firebase-login.mjs --reauth --no-localhost",
    "firebase:whoami": "node scripts/firebase-whoami.mjs",
    "deploy:firebase-rules": "node --use-system-ca --require ./scripts/firebase-cli-no-keepalive.cjs scripts/deploy-firebase-rules-admin.mjs",
    "deploy:firebase-auth": "node scripts/deploy-firebase-auth.mjs",
    "oauth:local-setup": "node scripts/print-google-oauth-local-setup.mjs",
    "oauth:apple-setup": "node scripts/print-apple-oauth-setup.mjs",
    "business:sync-directory": "node scripts/inspect-business-directory.mjs",
    "deploy:firebase-functions": "node scripts/deploy-firebase-functions.mjs",
    "deploy:firebase-functions:sa": "node scripts/deploy-firebase-functions.mjs --sa",
    "commerce:switch-live": "node scripts/switch-commerce-live.mjs",
    "commerce:deploy-live": "node scripts/switch-commerce-live.mjs --deploy",
    "credits:reset-all": "node scripts/reset-all-credits.mjs",
    "credits:reset-all:execute": "node scripts/reset-all-credits.mjs --execute",
    "set:firebase-admin-env": "node scripts/set-firebase-admin-env-from-json.mjs",
    "minify:service-account": "node scripts/minify-service-account-json.mjs",
    "lint": "eslint src api functions/scripts --ext js,jsx --report-unused-disable-directives",
    "lint:bidi": "eslint --no-eslintrc --config .eslintrc.bidi.cjs src/components src/pages src/admin --ext js,jsx",
    "lint:bidi:summary": "node scripts/lint-bidi-summary.mjs",
    "codemod:bidi": "node scripts/codemod-bidi.mjs --write",
    "fix:bidi-imports": "node scripts/fix-bidi-imports.mjs",
    "lint:ci": "eslint src api functions/scripts --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:live": "npx --yes serve dist -p 4173",
    "wipe-firebase-user-data": "node scripts/wipe-firebase-user-data.mjs",
    "wipe-firebase-user-data:execute": "node scripts/wipe-firebase-user-data.mjs --execute",
    "locale:audit": "node scripts/audit-t-keys.mjs",
    "locale:compare": "node scripts/compare-locales.mjs",
    "locale:merge-missing": "node scripts/merge-missing-locales.mjs",
    "locale:sync": "node scripts/sync-all-locales.mjs",
    "locale:merge-batches": "node scripts/merge-all-locale-batches.mjs",
    "locale:translate-hi": "node scripts/translate-locale-mymemory.mjs hi --full",
    "locale:translate-ur": "node scripts/translate-locale-mymemory.mjs ur --full",
    "locale:translate-batch": "node scripts/translate-untranslated-batch.mjs",
    "locale:coverage": "node scripts/audit-locale-coverage.mjs",
    "locale:fix-defaults": "node scripts/normalize-t-defaults.mjs --write",
    "locale:merge-admin": "node scripts/merge-admin-locales.mjs",
    "locale:sync-fr": "node scripts/sync-fr-locale.mjs",
    "locale:build-fr": "node scripts/build-fr-locale.mjs",
    "locale:finish": "node scripts/finish-i18n.mjs && node scripts/fill-missing-locale-keys.mjs && node scripts/scan-i18n-keys.mjs",
    "deploy:community-moderation": "firebase deploy --only \"functions:default:setCommunityMembership,functions:default:listCommunityMembers,firestore:rules\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paypal/react-paypal-js": "^10.1.1",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "browser-image-compression": "^2.0.2",
    "country-state-city": "^3.2.1",
    "emoji-picker-react": "^4.18.0",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lottie-react": "^2.4.1",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.22.0",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vercel": "^50.42.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "eslint-plugin-bidi": "file:eslint-plugin-bidi",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1"
  }
}
